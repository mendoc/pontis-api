FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache openssl

# Copy tsconfig.base.json from monorepo root so ../tsconfig.base.json resolves correctly
COPY tsconfig.base.json /tsconfig.base.json

COPY api/package*.json ./
COPY api/prisma ./prisma/

# --ignore-scripts skips postinstall (prisma migrate deploy needs a running DB — handled at startup)
RUN npm pkg delete scripts.postinstall && npm install && npx prisma generate

COPY api/scripts/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 3001

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "run", "dev"]
