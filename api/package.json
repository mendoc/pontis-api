{
  "name": "@pontis/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "set -a && . ../.env && set +a && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "set -a && . ../.env && set +a && node dist/index.js",
    "db:migrate": "set -a && . ../.env && set +a && prisma migrate dev",
    "db:generate": "set -a && . ../.env && set +a && prisma generate",
    "db:studio": "set -a && . ../.env && set +a && prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "node-forge": "^1.3.1",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/node-forge": "^1.3.11",
    "@types/passport": "^1.0.16",
    "@types/passport-oauth2": "^1.4.17",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
